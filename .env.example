# ── Google Cloud (single service account for Drive + Vertex AI) ───────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/service_account.json

# Google Drive — folder containing MAO process documents
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# ── Vertex AI — Embeddings (text-embedding-004) ───────────────────────────────
GOOGLE_CLOUD_LOCATION=us-central1       # Vertex AI region for embeddings
VERTEX_EMBEDDING_MODEL=text-embedding-004

# ── Vertex AI — Claude (AnthropicVertex) ─────────────────────────────────────
VERTEX_CLAUDE_REGION=us-east5           # Claude on Vertex is available in us-east5
VERTEX_CLAUDE_MODEL=claude-sonnet-4-5@20250514

# ── Vertex AI — Vector Search (run scripts/setup_vertex_index.py once to get these) ──
VERTEX_VECTOR_SEARCH_INDEX_ID=123456789          # numeric ID printed by setup script
VERTEX_VECTOR_SEARCH_ENDPOINT_ID=987654321       # numeric ID printed by setup script
VERTEX_VECTOR_SEARCH_DEPLOYED_INDEX_ID=openclaw_mao
VECTOR_METADATA_DB_PATH=./data/chunks.db         # local SQLite sidecar for chunk text/metadata

# ── Microsoft Teams Bot Framework ────────────────────────────────────────────
MicrosoftAppId=your-teams-app-id
MicrosoftAppPassword=your-teams-app-password
BOT_PORT=3978

# ── RAG Settings (optional — defaults shown) ─────────────────────────────────
TOP_K_CHUNKS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_SCORE_THRESHOLD=0.75
